{
  "name": "Better Agilix Buzz",
  "version": "0.1.0",
  "description": "Making BrightThinker more customizeable",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.agilixbuzz.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.agilixbuzz.com/*"
      ],
      "js": [
        "contentScript.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [],
      "matches": [
        "*://*.agilixbuzz.com/*"
      ]
    }
  ],
  "action": {
    "default_icon": {
      "16": "assets/ext-icon.png",
      "24": "assets/ext-icon.png",
      "32": "assets/ext-icon.png"
    },
    "default_title": "Better Agilix Buzz",
    "default_popup": "popup.html"
  },
  "manifest_version": 3
}